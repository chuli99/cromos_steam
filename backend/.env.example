# Configuración del backend (prefijo SCP_). Copiá este archivo a .env y ajustá.
# Todos los valores tienen default razonable en config.py; .env solo sobrescribe.

# --- Moneda / localización ---
# Moneda del market para priceoverview. 1 = USD (recomendado por estabilidad).
SCP_CURRENCY=1
# Código de país para appdetails (precio del juego).
SCP_COUNTRY_CODE=ar
# Idioma para appdetails.
SCP_LANGUAGE=spanish

# --- TTLs de caché (segundos) ---
SCP_CACHE_TTL_CARDS=21600       # precio de cromos: 6h
SCP_CACHE_TTL_GAME=3600         # precio del juego: 1h
SCP_CACHE_TTL_CARD_LIST=86400   # lista de cromos: 24h

# --- Rate limiting por host de Steam (intervalo mínimo entre requests, s) ---
# Bien por debajo del máximo de Steam: priceoverview es una ventana deslizante que,
# sostenida cerca del tope (~20 req/min), igual bloquea la IP por minutos. En escaneos
# largos (cientos de boosters) conviene prevenir, no absorber. Subí community si seguís
# viendo 429 (ej. 6.0 = 10 req/min); bajalo si querés más velocidad y poco volumen.
SCP_COMMUNITY_INTERVAL=5.0      # steamcommunity.com (priceoverview/search): ~12 req/min
SCP_STORE_INTERVAL=2.0          # store.steampowered.com (appdetails): ~150 req/5min (máx ~200)
SCP_THROTTLE_CONCURRENCY=1      # requests concurrentes por host
SCP_MAX_RETRIES=6               # reintentos ante 429/5xx/red (absorbe bloqueos transitorios)
SCP_BACKOFF_BASE=2.0            # base del backoff exponencial (s)
SCP_BACKOFF_MAX=60.0            # tope del backoff / Retry-After (s)
SCP_COOLDOWN_429=60.0           # pausa del host ante un 429 sin Retry-After (s)

# --- Cálculo ---
SCP_FEE_RATE=0.15               # fee de Steam (5% + 10%)
SCP_DROP_RATIO=0.5              # proporción del set que dropea (la mitad)

# --- HTTP ---
SCP_HTTP_TIMEOUT=15.0

# --- CORS ---
# Origins permitidos (separados por coma). La extensión usa chrome-extension://
# que ya se permite por regex en el código.
SCP_CORS_ORIGINS_RAW=http://localhost,http://localhost:8000
